  {
    "id": 4,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
    "jp": "よかったですよ。",
    "kana": "よかったですよ。",
    "romaji": "yokatta desu yo.",
    "zh": "很好喔。",
    "start": 7.47,
    "end": 8.73
  },
  {
    "id": 5,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
    "jp": "何をしましたか。",
    "kana": "なにをしましたか。",
    "romaji": "nani o shimashita ka.",
    "zh": "做了什麼？",
    "start": 9.76,
    "end": 10.95
  },
  {
    "id": 6,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
    "jp": "うえのに行きました。",
    "kana": "うえのにいきました。",
    "romaji": "ueno ni ikimashita.",
    "zh": "去了上野。",
    "start": 11.98,
    "end": 13.24
  },
  {
    "id": 7,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
    "jp": "それから、",
    "kana": "それから、",
    "romaji": "sorekara,",
    "zh": "然後，",
    "start": 14.3,
    "end": 14.89
  },
  {
    "id": 8,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
    "jp": "おみやげも買いました。",
    "kana": "おみやげもかいました。",
    "romaji": "omiyage mo kaimashita.",
    "zh": "也買了伴手禮。",
    "start": 15.34,
    "end": 16.83
  },
  {
    "id": 9,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
    "jp": "そうですか。",
    "kana": "そうですか。",
    "romaji": "sou desu ka.",
    "zh": "這樣啊。",
    "start": 17.88,
    "end": 19.03
  },
  {
    "id": 10,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
