  {
    "id": 3,
    "audio": "1_maria_san.m4a",
    "speaker": "マリアさん",
    "jp": "東京はどうでしたか。",
    "kana": "とうきょうはどうでしたか。",
    "romaji": "toukyou wa dou deshita ka.",
    "zh": "東京怎麼樣？",
    "start": 4.93,
    "end": 6.4
